# ═══════════════════════════════════════════════════════════════════════════════
# Savdo — Root Environment Variables
# Скопируй в .env и заполни. ❌ Никогда не коммить .env.
#
# Этот файл — общий для всех приложений (apps/api / apps/admin / apps/tma /
# apps/web-buyer / apps/web-seller). Каждое приложение также имеет свой
# apps/<name>/.env.example с переменными специфичными именно для него.
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# App (apps/api)
# ───────────────────────────────────────────────────────────────────────────────
NODE_ENV=development                # development | production | test
PORT=3000
APP_URL=http://localhost:3000

# ───────────────────────────────────────────────────────────────────────────────
# Database — PostgreSQL
# Railway: подставляется автоматически из PostgreSQL plugin
# ───────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/savdo

# ───────────────────────────────────────────────────────────────────────────────
# Redis
# Railway: подставляется автоматически
# ───────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────────────────────────
# JWT — минимум 32 символа
# Генерируй: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ───────────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=                  # ОБЯЗАТЕЛЬНО
JWT_REFRESH_SECRET=                 # ОБЯЗАТЕЛЬНО
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ───────────────────────────────────────────────────────────────────────────────
# Storage — Cloudflare R2 / Supabase S3 (S3-compatible)
# Можно оставить пустым — загрузка файлов будет отключена
# Telegram-bucket — DEPRECATED (см. API-MEDIA-MIGRATION-TG-TO-R2-001)
# ───────────────────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_PUBLIC=savdo-public
STORAGE_BUCKET_PRIVATE=savdo-private
STORAGE_PUBLIC_URL=                 # https://cdn.savdo.uz или pub-xxx.r2.dev
STORAGE_REGION=auto

# ───────────────────────────────────────────────────────────────────────────────
# Telegram Bot — единственный source OTP и уведомлений
# ❌ SMS/Eskiz/Playmobile ЗАПРЕЩЕНЫ (CLAUDE.md key rule #0)
# ───────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # ОБЯЗАТЕЛЬНО — токен от @BotFather
TELEGRAM_BOT_USERNAME=savdo_builderBOT
TELEGRAM_WEBHOOK_SECRET=            # опционально — Railway secret для верификации
TMA_URL=                            # публичный URL apps/tma после деплоя

# ───────────────────────────────────────────────────────────────────────────────
# CORS — через запятую без пробелов
# ───────────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ───────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ───────────────────────────────────────────────────────────────────────────────
DEV_OTP_ENABLED=true                # OTP в логах вместо TG (development only!)
STORE_APPROVAL_REQUIRED=true        # модерация магазинов перед публикацией
CHAT_ENABLED=true
ANALYTICS_ENABLED=true
TELEGRAM_NOTIFICATIONS_ENABLED=false
OTP_REQUIRED_FOR_CHECKOUT=false
WEB_PUSH_ENABLED=false
MOBILE_PUSH_ENABLED=false
SELLER_INSIGHTS_ENABLED=false
PAYMENT_ONLINE_ENABLED=false
PRODUCT_IMAGE_ATTACHMENT_ENABLED=false

# Cron / Background jobs (Wave 10, 14)
CART_ABANDONMENT_ENABLED=true       # @EVERY_HOUR cron в CartAbandonmentService
WISHLIST_NOTIFY_ENABLED=true        # @EVERY_4_HOURS cron в WishlistNotifyService

# Auto-cancel pending orders (часов)
AUTO_CANCEL_PENDING_AFTER_HOURS=48

# ───────────────────────────────────────────────────────────────────────────────
# Observability (Wave 17, 18)
# ───────────────────────────────────────────────────────────────────────────────
# StructuredLogger log level: verbose | debug | log | warn | error | fatal
# Default в prod: 'log' (verbose/debug отключены).
LOG_LEVEL=
# Lightweight error reporter (auto-capture + manual API)
ERROR_REPORTER_ENABLED=true

# ───────────────────────────────────────────────────────────────────────────────
# Frontend public vars (Next.js + Vite)
# Дублирую тут для удобства локального dev. Per-app .env.example — в apps/<name>/
# ───────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000
VITE_BOT_USERNAME=savdo_builderBOT

# Yandex Maps Suggest API (Wave 14 — TMA-ADDRESS-AUTOCOMPLETE-001)
# Опционально: без ключа AddressAutocomplete деградирует на обычный input
VITE_YANDEX_MAPS_API_KEY=
