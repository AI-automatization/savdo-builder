# ================================
# Savdo — Environment Variables
# Copy to .env and fill in values
# ================================

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/savdo_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Storage (Cloudflare R2 — S3-compatible)
STORAGE_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_PUBLIC=savdo-public
STORAGE_BUCKET_PRIVATE=savdo-private
STORAGE_PUBLIC_URL=https://pub-HASH.r2.dev

# OTP — Eskiz.uz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=savdo

# Telegram Bot
TELEGRAM_BOT_TOKEN=
# TMA (Telegram Mini App) — публичный URL приложения apps/tma
TMA_URL=

# Feature Flags
CHAT_ENABLED=true
OTP_REQUIRED_FOR_CHECKOUT=false
STORE_APPROVAL_REQUIRED=false
WEB_PUSH_ENABLED=false
MOBILE_PUSH_ENABLED=false
TELEGRAM_NOTIFICATIONS_ENABLED=false
SMS_FALLBACK_ENABLED=false
ANALYTICS_ENABLED=true
SELLER_INSIGHTS_ENABLED=false
DEV_OTP_ENABLED=true
PAYMENT_ONLINE_ENABLED=false
PRODUCT_IMAGE_ATTACHMENT_ENABLED=false

# Auto-cancel pending orders (hours)
AUTO_CANCEL_PENDING_AFTER_HOURS=48

# Web apps (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000
