# ═══════════════════════════════════════════════════════════════════════════════
# Savdo API — Railway Environment Variables
# Копируй этот файл в Railway → Service → Variables
# Значения с ${{...}} Railway подставляет сам из плагинов
# Остальные — заполни вручную
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
ALLOWED_ORIGINS=https://${{RAILWAY_PUBLIC_DOMAIN}},https://savdo.uz,https://seller.savdo.uz,https://buyer.savdo.uz

# ── Database (Railway PostgreSQL plugin) ──────────────────────────────────────
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Redis (Railway Redis plugin) ──────────────────────────────────────────────
REDIS_URL=${{Redis.REDIS_URL}}

# ── JWT ────────────────────────────────────────────────────────────────────────
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=REPLACE_WITH_GENERATED_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
# Account ID → Cloudflare Dashboard → R2 Overview → Account ID
STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY
STORAGE_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_KEY
STORAGE_BUCKET_PUBLIC=savdo-public
STORAGE_BUCKET_PRIVATE=savdo-private
# Публичный URL бакета → Cloudflare R2 → savdo-public → Settings → Public Access
STORAGE_PUBLIC_URL=https://pub-REPLACE.r2.dev

# ── Telegram Bot OTP ──────────────────────────────────────────────────────────
# ❌ Eskiz.uz ЗАПРЕЩЁН — OTP только через Telegram Bot API
# Токен бота: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_BOT_USERNAME=savdo_builderBOT
# Секрет для Telegram webhook (любая случайная строка)
# Установить через: POST https://api.telegram.org/bot<TOKEN>/setWebhook
#   body: { url: "https://YOUR_DOMAIN/api/v1/telegram/webhook", secret_token: "WEBHOOK_SECRET" }
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Feature Flags ─────────────────────────────────────────────────────────────
DEV_OTP_ENABLED=false
STORE_APPROVAL_REQUIRED=false
CHAT_ENABLED=true
ANALYTICS_ENABLED=true
TELEGRAM_NOTIFICATIONS_ENABLED=true
OTP_REQUIRED_FOR_CHECKOUT=false
WEB_PUSH_ENABLED=false
MOBILE_PUSH_ENABLED=false
SMS_FALLBACK_ENABLED=false
SELLER_INSIGHTS_ENABLED=false
PAYMENT_ONLINE_ENABLED=false
PRODUCT_IMAGE_ATTACHMENT_ENABLED=false
AUTO_CANCEL_PENDING_AFTER_HOURS=48

# ── CORS ──────────────────────────────────────────────────────────────────────
# Добавь домены фронтенда через запятую (без пробелов)
# ALLOWED_ORIGINS уже выставлен выше
