# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://savdo-api-production.up.railway.app
ALLOWED_ORIGINS=https://savdo-api-production.up.railway.app

# ── Database (Railway PostgreSQL plugin → используй ${{Postgres.DATABASE_URL}}) ──
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Redis (Railway Redis plugin → используй ${{Redis.REDIS_URL}}) ─────────────
REDIS_URL=${{Redis.REDIS_URL}}

# ── JWT (сгенерированные секреты) ─────────────────────────────────────────────
JWT_ACCESS_SECRET=/KQ0KZf+31LLOCsmCmwI/loZvK6Y27mh2LyZYAnSlg4=
JWT_REFRESH_SECRET=mSlNfIRo45eNUntD8hUMBS0wW321zYG/GDAO/0eMgH0=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_PUBLIC=savdo-public
STORAGE_BUCKET_PRIVATE=savdo-private
STORAGE_PUBLIC_URL=https://pub-HASH.r2.dev

# ── Telegram Bot (@BotFather → /newbot) ───────────────────────────────────────
