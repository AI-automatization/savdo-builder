# ═══════════════════════════════════════════════════════════════════════════════
# Savdo API — Railway Environment Variables
# Копируй всё ниже в Railway → savdo-api → Variables → RAW Editor
# Значения с ${{...}} Railway подставляет сам (PostgreSQL + Redis plugin)
# Остальные уже заполнены — просто вставь
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000

# Railway подставляет сам из плагинов
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# JWT — уже сгенерированы
JWT_ACCESS_SECRET=wnf0+blR+m0zSlyb+bhWSoRx33Q+Ytl/qq/vvfJh+E9vtaumILLWbcen2n2I8T5R
JWT_REFRESH_SECRET=GEV4BnINgcR90RyS3Kqe8qLDF339LPgWVOKSSn2RkBEYxBN05KpoIAwacpvGvLxI
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Telegram Bot OTP (@savdo_builderBOT)
TELEGRAM_BOT_TOKEN=8682354018:AAE7U_p2bcQLyPra3K9cjPYXx-cSwlMwaXE
TELEGRAM_BOT_USERNAME=savdo_builderBOT
TELEGRAM_WEBHOOK_SECRET=99f000d0e6c069133263ba65f6629898f4e5f4484036d5f7

# Feature flags
DEV_OTP_ENABLED=false
STORE_APPROVAL_REQUIRED=false
CHAT_ENABLED=true
ANALYTICS_ENABLED=true
TELEGRAM_NOTIFICATIONS_ENABLED=true
OTP_REQUIRED_FOR_CHECKOUT=false
WEB_PUSH_ENABLED=false
MOBILE_PUSH_ENABLED=false
SMS_FALLBACK_ENABLED=false
SELLER_INSIGHTS_ENABLED=false
