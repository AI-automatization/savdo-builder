# ═══════════════════════════════════════════════════════════════════════════════
# Savdo API — Environment Variables
# Скопируй в .env и заполни значения.
# ❌ Никогда не коммить .env — только этот файл!
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# App
# ───────────────────────────────────────────────────────────────────────────────
NODE_ENV=development            # development | production | test
PORT=3000
APP_URL=http://localhost:3000   # публичный URL апи (Railway подставит свой домен)

# ───────────────────────────────────────────────────────────────────────────────
# Database — PostgreSQL
# Railway: значение подставляется автоматически из PostgreSQL plugin
# Локально: postgresql://user:password@localhost:5432/savdo
# ───────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/savdo

# ───────────────────────────────────────────────────────────────────────────────
# Redis
# Railway: значение подставляется автоматически из Redis plugin
# Локально: redis://localhost:6379
# ───────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────────────────────────
# JWT — генерируй командой:
# node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('base64'));"
# Минимум 32 символа — иначе API упадёт при старте!
# ───────────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=                  # ОБЯЗАТЕЛЬНО — минимум 32 символа
JWT_REFRESH_SECRET=                 # ОБЯЗАТЕЛЬНО — минимум 32 символа
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ───────────────────────────────────────────────────────────────────────────────
# Telegram Bot — OTP и уведомления
# @BotFather → /newbot → скопируй токен
# ❌ SMS/Eskiz ЗАПРЕЩЕНЫ — только Telegram Bot API
# ───────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # ОБЯЗАТЕЛЬНО — токен от @BotFather
TELEGRAM_BOT_USERNAME=savdo_builderBOT
TELEGRAM_WEBHOOK_SECRET=            # опционально — для верификации вебхуков Railway

# ───────────────────────────────────────────────────────────────────────────────
# CORS
# Через запятую без пробелов: https://savdo.uz,https://seller.savdo.uz
# ───────────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ───────────────────────────────────────────────────────────────────────────────
# Storage — Cloudflare R2 (S3-compatible)
# Можно оставить пустым — загрузка файлов будет отключена
# ───────────────────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=                   # https://<accountid>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_PUBLIC=savdo-public
STORAGE_BUCKET_PRIVATE=savdo-private
STORAGE_PUBLIC_URL=                 # https://cdn.savdo.uz

# ───────────────────────────────────────────────────────────────────────────────
# Feature Flags
# true/false — управляют включением фич без редеплоя
# ───────────────────────────────────────────────────────────────────────────────

# DEV: OTP в логах вместо Telegram (только development!)
DEV_OTP_ENABLED=false

# Магазин требует одобрения модератором перед публикацией
STORE_APPROVAL_REQUIRED=true

# Real-time чат покупатель ↔ продавец (Socket.IO)
CHAT_ENABLED=true

# Аналитика продаж и трафика
ANALYTICS_ENABLED=true

# Уведомления в Telegram продавцу (новый заказ, статусы)
TELEGRAM_NOTIFICATIONS_ENABLED=false

# OTP подтверждение при оформлении заказа
OTP_REQUIRED_FOR_CHECKOUT=false

# Web Push уведомления (браузер)
WEB_PUSH_ENABLED=false

# Mobile Push уведомления (Expo)
MOBILE_PUSH_ENABLED=false

# SMS fallback — ВСЕГДА false, SMS/Eskiz ЗАПРЕЩЕНЫ
SMS_FALLBACK_ENABLED=false

# Аналитика для продавца (топ товары, конверсия)
SELLER_INSIGHTS_ENABLED=false

# Онлайн-оплата (Payme / Click)
PAYMENT_ONLINE_ENABLED=false

# Прикрепление изображений к товарам через R2
PRODUCT_IMAGE_ATTACHMENT_ENABLED=false

# Автоотмена неоплаченных заказов через N часов
AUTO_CANCEL_PENDING_AFTER_HOURS=48
