# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://savdo-api-production.up.railway.app
ALLOWED_ORIGINS=https://savdo-api-production.up.railway.app

# ── Database (Railway PostgreSQL plugin) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@crossover.proxy.rlwy.net:37242/railway

# ── Redis (Railway Redis plugin) ──────────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@monorail.proxy.rlwy.net:PORT

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_PUBLIC=savdo-public
STORAGE_BUCKET_PRIVATE=savdo-private
STORAGE_PUBLIC_URL=https://pub-HASH.r2.dev

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── OTP (Eskiz.uz) ────────────────────────────────────────────────────────────
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# ── Feature Flags ─────────────────────────────────────────────────────────────
DEV_OTP_ENABLED=false
STORE_APPROVAL_REQUIRED=false
CHAT_ENABLED=true
ANALYTICS_ENABLED=true
TELEGRAM_NOTIFICATIONS_ENABLED=false
OTP_REQUIRED_FOR_CHECKOUT=false
WEB_PUSH_ENABLED=false
MOBILE_PUSH_ENABLED=false
SMS_FALLBACK_ENABLED=false
SELLER_INSIGHTS_ENABLED=false
PAYMENT_ONLINE_ENABLED=false
PRODUCT_IMAGE_ATTACHMENT_ENABLED=false
AUTO_CANCEL_PENDING_AFTER_HOURS=48
