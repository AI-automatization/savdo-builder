# ═══════════════════════════════════════════════════════════════════
# web-seller — Railway Variables
# Вставь в Railway → web-seller → Variables → RAW Editor
# ═══════════════════════════════════════════════════════════════════

NODE_ENV=production
NEXT_PUBLIC_API_URL=https://savdo-api-production.up.railway.app
NEXT_PUBLIC_BUYER_URL=https://savdo-builder-by-production.up.railway.app
# Slug живого публичного магазина для кнопки «Посмотреть демо» на лендинге.
# Если пусто — используется дефолт в коде (demo-store.ts → azim-mnx4na25).
NEXT_PUBLIC_DEMO_STORE_SLUG=azim-mnx4na25
# (Опционально) живые магазины для будущей вариации showcase — slug через запятую.
# Секция «Витрины» на лендинге сейчас показывает курируемые премиум-примеры
# (не зависит от этой переменной).
NEXT_PUBLIC_SHOWCASE_SLUGS=
NEXT_PUBLIC_TG_BOT_USERNAME=maxsavdo_bot
# Telegram-ссылка на канал поддержки. Если пусто — фолбэк на бот @maxsavdo_bot.
# Заполняется Полатом после создания канала (SUPPORT-CHANNEL-001).
NEXT_PUBLIC_SUPPORT_URL=
