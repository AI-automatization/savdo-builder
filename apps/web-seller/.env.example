# ═══════════════════════════════════════════════════════════════════
# web-seller — Railway Variables
# Вставь в Railway → web-seller → Variables → RAW Editor
# ═══════════════════════════════════════════════════════════════════

NODE_ENV=production
NEXT_PUBLIC_API_URL=https://savdo-api-production.up.railway.app
NEXT_PUBLIC_BUYER_URL=https://savdo-builder-by-production.up.railway.app
# Slug магазина-витрины для кнопки «Посмотреть демо» на лендинге.
# Если пусто — кнопка демо не показывается. В dev есть сид-магазин 'test-store'.
NEXT_PUBLIC_DEMO_STORE_SLUG=test-store
# Витрины для секции «Витрины» (showcase) на лендинге — slug магазинов через запятую.
# Если пусто — секция не рендерится (никаких мёртвых ссылок в проде).
NEXT_PUBLIC_SHOWCASE_SLUGS=
NEXT_PUBLIC_TG_BOT_USERNAME=savdo_builderBOT
