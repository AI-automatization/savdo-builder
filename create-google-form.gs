/**
 * savdo-builder — Google Form: опрос потенциальных клиентов
 *
 * КАК ИСПОЛЬЗОВАТЬ:
 * 1. Открой https://script.google.com
 * 2. Нажми "Новый проект"
 * 3. Удали весь код и вставь этот файл целиком
 * 4. Нажми ▶ Run (или Ctrl+R)
 * 5. Разреши доступ к Google Forms (один раз)
 * 6. В логах (View → Logs) появятся две ссылки:
 *    - Form URL  — для respondents (делиться)
 *    - Edit URL  — для редактирования формы
 */

function createSavdoBuilderForm() {

  // ── Создаём форму ──────────────────────────────────────────────────────────
  var form = FormApp.create('Нужен ли вашему бизнесу интернет-магазин?');

  form.setDescription(
    'Мы разрабатываем платформу savdo-builder — сервис для быстрого создания ' +
    'интернет-магазинов. Ответьте на 15 вопросов (3 минуты) — ваши ответы ' +
    'помогут нам сделать продукт именно для вашей сферы.'
  );
  form.setConfirmationMessage('Спасибо за ваши ответы! Мы свяжемся с вами в ближайшее время 🙏');
  form.setShowLinkToRespondAgain(false);
  form.setProgressBar(true);
  form.setShuffleQuestions(false);

  // ── Вопрос 1 ───────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('1. В какой сфере работает ваш бизнес?')
    .setRequired(true)
    .setChoices([
      form.addMultipleChoiceItem().createChoice('Одежда и обувь'),
      form.addMultipleChoiceItem().createChoice('Продукты питания'),
      form.addMultipleChoiceItem().createChoice('Электроника и гаджеты'),
      form.addMultipleChoiceItem().createChoice('Косметика и бьюти'),
      form.addMultipleChoiceItem().createChoice('Строительство и ремонт'),
      form.addMultipleChoiceItem().createChoice('Детские товары'),
      form.addMultipleChoiceItem().createChoice('Мебель и интерьер'),
      form.addMultipleChoiceItem().createChoice('Другое'),
    ]);

  // ── Вопрос 2 ───────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('2. Есть ли у вас физическая точка продаж?')
    .setRequired(true)
    .setChoiceValues([
      'Да, только физический магазин',
      'Да, и физический и онлайн',
      'Нет, только онлайн',
      'Пока не продаю, только планирую',
    ]);

  // ── Вопрос 3 ───────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('3. Продаёте ли вы товары онлайн прямо сейчас?')
    .setRequired(true)
    .setChoiceValues([
      'Да',
      'Нет, но хочу начать',
      'Нет и не планирую',
    ]);

  // ── Вопрос 4 ───────────────────────────────────────────────────────────────
  form.addCheckboxItem()
    .setTitle('4. Если продаёте онлайн — где именно? (можно несколько)')
    .setRequired(false)
    .setChoiceValues([
      'Instagram / Telegram канал',
      'OLX.uz / Daryo.uz',
      'Собственный сайт',
      'Uzum Market / другие маркетплейсы',
      'Нигде не продаю онлайн',
    ]);

  // ── Вопрос 5 ───────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('5. Сколько наименований товаров у вас в ассортименте?')
    .setRequired(true)
    .setChoiceValues([
      'До 50',
      '50 – 200',
      '200 – 1 000',
      'Более 1 000',
    ]);

  // ── Вопрос 6 ───────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('6. Сколько заказов вы получаете (или хотели бы получать) в месяц?')
    .setRequired(true)
    .setChoiceValues([
      'До 30',
      '30 – 100',
      '100 – 500',
      'Более 500',
    ]);

  // ── Вопрос 7 ───────────────────────────────────────────────────────────────
  form.addCheckboxItem()
    .setTitle('7. Какие функции нужны вам в интернет-магазине? (можно несколько)')
    .setRequired(true)
    .setChoiceValues([
      'Каталог товаров с фото и ценами',
      'Онлайн-оплата (Payme, Click)',
      'Корзина и оформление заказа',
      'Управление доставкой',
      'CRM / база клиентов',
      'Аналитика и статистика продаж',
      'Мобильное приложение',
      'Интеграция с Instagram',
    ]);

  // ── Вопрос 8 ───────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('8. Принимаете ли вы онлайн-оплату сейчас?')
    .setRequired(true)
    .setChoiceValues([
      'Да (Payme, Click и т.д.)',
      'Нет, только наличные / банковский перевод',
      'Хочу подключить, но не знаю как',
    ]);

  // ── Вопрос 9 ───────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('9. Насколько вы разбираетесь в технологиях и сайтах?')
    .setRequired(true)
    .setChoiceValues([
      'Хорошо — могу всё настроить сам',
      'Базово — умею пользоваться Instagram, Telegram',
      'Слабо — нужна помощь в настройке',
      'Совсем не разбираюсь',
    ]);

  // ── Вопрос 10 ──────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('10. Есть ли у вас сотрудник, который мог бы вести сайт?')
    .setRequired(true)
    .setChoiceValues([
      'Да, есть',
      'Нет, всё делаю сам',
      'Нет, но готов нанять',
    ]);

  // ── Вопрос 11 ──────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('11. Какой бюджет вы готовы выделить на интернет-магазин?')
    .setRequired(true)
    .setChoiceValues([
      'До 500 000 сум/мес',
      '500 000 – 1 500 000 сум/мес',
      '1 500 000 – 3 000 000 сум/мес',
      'Более 3 000 000 сум/мес',
      'Зависит от функционала — нужно обсудить',
    ]);

  // ── Вопрос 12 ──────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('12. Какой формат оплаты вам удобнее?')
    .setRequired(true)
    .setChoiceValues([
      'Ежемесячная подписка',
      'Разовая оплата (один раз навсегда)',
      'Процент от продаж',
      'Сначала бесплатный пробный период, потом решу',
    ]);

  // ── Вопрос 13 ──────────────────────────────────────────────────────────────
  form.addMultipleChoiceItem()
    .setTitle('13. Как быстро вам нужен готовый интернет-магазин?')
    .setRequired(true)
    .setChoiceValues([
      'Как можно скорее — уже вчера',
      'В течение 1 месяца',
      'В течение 3 месяцев',
      'Пока только изучаю варианты',
    ]);

  // ── Вопрос 14 ──────────────────────────────────────────────────────────────
  form.addCheckboxItem()
    .setTitle('14. Что мешает вам запустить интернет-магазин прямо сейчас? (можно несколько)')
    .setRequired(true)
    .setChoiceValues([
      'Слишком дорого',
      'Не знаю с чего начать',
      'Нет времени заниматься',
      'Не уверен, будет ли эффект',
      'Уже есть решение и всё устраивает',
      'Ничего не мешает — готов начать',
    ]);

  // ── Вопрос 15 ──────────────────────────────────────────────────────────────
  form.addTextItem()
    .setTitle('15. Оставьте контакт — мы свяжемся и расскажем подробнее')
    .setHelpText('Имя и номер телефона или @username в Telegram (необязательно)')
    .setRequired(false);

  // ── Логи со ссылками ───────────────────────────────────────────────────────
  Logger.log('✅ Форма создана!');
  Logger.log('🔗 Ссылка для респондентов: ' + form.getPublishedUrl());
  Logger.log('✏️  Ссылка для редактирования: ' + form.getEditUrl());
  Logger.log('📊 Ответы (таблица): создай вручную через Responses → Link to Sheets');
}
