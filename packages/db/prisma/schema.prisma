// Savdo — Prisma Schema
// Design docs: docs/V0.1/04_database_postgresql.md
// State machines: docs/V1.1/02_state_machines.md
// Invariants: docs/V1.1/01_domain_invariants.md

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum StoreStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

enum SellerVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  HIDDEN_BY_ADMIN
}

enum PaymentMethod {
  COD
  MANUAL_TRANSFER
  ONLINE
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum ThreadType {
  PRODUCT
  ORDER
}

enum MediaVisibility {
  PUBLIC
  PROTECTED
  PRIVATE
}

enum InventoryMovementType {
  ORDER_DEDUCTED
  ORDER_RELEASED
  MANUAL_ADJUSTMENT
}

// ─────────────────────────────────────────────
// IDENTITY
// ─────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  role             UserRole
  phone            String     @unique
  email            String?
  telegramId       BigInt?    @unique
  status           UserStatus @default(ACTIVE)
  isPhoneVerified  Boolean    @default(false)
  languageCode     String     @default("ru")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  referredBy String?

  buyer    Buyer?
  seller   Seller?
  admin         AdminUser?
  sessions      UserSession[]
  auditLogs     AuditLog[]
  broadcastLogs BroadcastLog[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String
  deviceType       String?
  deviceName       String?
  ipAddress        String?
  userAgent        String?
  lastSeenAt       DateTime @default(now())
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model OtpRequest {
  id          String    @id @default(uuid())
  phone       String
  codeHash    String
  purpose     String    // login | register | checkout
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_requests")
}

// ─────────────────────────────────────────────
// BUYER
// ─────────────────────────────────────────────

model Buyer {
  id               String   @id @default(uuid())
  userId           String   @unique
  firstName        String?
  lastName         String?
  telegramUsername String?
  avatarUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id])
  addresses BuyerAddress[]
  carts     Cart[]
  orders    Order[]
  threads   ChatThread[]

  @@map("buyers")
}

model BuyerAddress {
  id           String   @id @default(uuid())
  buyerId      String
  label        String?
  fullName     String
  phone        String
  city         String
  region       String?
  addressLine1 String
  addressLine2 String?
  landmark     String?
  postalCode   String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  buyer Buyer @relation(fields: [buyerId], references: [id])

  @@index([buyerId])
  @@map("buyer_addresses")
}

// ─────────────────────────────────────────────
// SELLER & STORE
// ─────────────────────────────────────────────

model Seller {
  id                          String                   @id @default(uuid())
  userId                      String                   @unique
  fullName                    String
  sellerType                  String                   // individual | business
  telegramUsername            String
  telegramChatId              BigInt?
  telegramNotificationsActive Boolean                  @default(false)
  verificationStatus          SellerVerificationStatus @default(UNVERIFIED)
  isBlocked                   Boolean                  @default(false)
  blockedReason               String?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  user      User                          @relation(fields: [userId], references: [id])
  store     Store?
  documents SellerVerificationDocument[]
  orders    Order[]
  threads   ChatThread[]

  @@index([isBlocked])
  @@map("sellers")
}

model SellerVerificationDocument {
  id           String   @id @default(uuid())
  sellerId     String
  documentType String   // passport | business_doc | other
  mediaId      String
  status       String   @default("pending")
  adminComment String?
  createdAt    DateTime @default(now())
  reviewedAt   DateTime?

  seller Seller     @relation(fields: [sellerId], references: [id])
  media  MediaFile  @relation(fields: [mediaId], references: [id])

  @@index([sellerId])
  @@map("seller_verification_documents")
}

model Store {
  id                     String      @id @default(uuid())
  sellerId               String      @unique  // INV-S01: one store per seller
  name                   String
  slug                   String      @unique
  description            String?
  logoMediaId            String?
  coverMediaId           String?
  status                 StoreStatus @default(DRAFT)
  primaryGlobalCategoryId String?
  city                   String
  region                 String?
  telegramContactLink    String
  telegramChannelId      String?     // @channel_username или числовой chat_id
  telegramChannelTitle   String?     // отображаемое название канала
  isPublic               Boolean     @default(false)
  publishedAt            DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  deletedAt              DateTime?

  seller           Seller                 @relation(fields: [sellerId], references: [id])
  primaryCategory  GlobalCategory?        @relation(fields: [primaryGlobalCategoryId], references: [id])
  contacts         StoreContact[]
  deliverySettings StoreDeliverySettings?
  categories       StoreCategory[]
  products         Product[]
  carts            Cart[]
  orders           Order[]

  @@index([status])
  @@index([isPublic])
  @@index([primaryGlobalCategoryId])
  @@map("stores")
}

model StoreContact {
  id          String   @id @default(uuid())
  storeId     String
  contactType String   // phone | telegram | instagram | other
  label       String?
  value       String
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@map("store_contacts")
}

model StoreDeliverySettings {
  id               String   @id @default(uuid())
  storeId          String   @unique
  supportsDelivery Boolean  @default(true)
  supportsPickup   Boolean  @default(false)
  deliveryFeeType  String   @default("fixed") // fixed | manual | none
  fixedDeliveryFee Decimal? @db.Decimal(12, 2)
  deliveryNotes    String?
  pickupNotes      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@map("store_delivery_settings")
}

// ─────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────

model GlobalCategory {
  id       String   @id @default(uuid())
  parentId String?
  nameRu   String
  nameUz   String
  slug     String   @unique
  isActive Boolean  @default(true)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())

  parent   GlobalCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children GlobalCategory[] @relation("CategoryTree")
  stores   Store[]
  products Product[]

  @@index([parentId])
  @@index([isActive])
  @@map("global_categories")
}

model CategoryFilter {
  id           String  @id @default(uuid())
  categorySlug String
  key          String
  nameRu       String
  nameUz       String
  fieldType    String  @default("TEXT")
  options      String?
  unit         String?
  sortOrder    Int     @default(0)

  @@unique([categorySlug, key])
  @@index([categorySlug])
  @@map("category_filters")
}

model StoreCategory {
  id        String   @id @default(uuid())
  storeId   String
  parentId  String?
  name      String
  slug      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store          @relation(fields: [storeId], references: [id])
  parent   StoreCategory? @relation("StoreCategoryTree", fields: [parentId], references: [id])
  children StoreCategory[] @relation("StoreCategoryTree")
  products Product[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("store_categories")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id                 String        @id @default(uuid())
  storeId            String
  globalCategoryId   String?
  storeCategoryId    String?
  title              String
  description        String?
  basePrice          Decimal       @db.Decimal(12, 2)
  oldPrice           Decimal?      @db.Decimal(12, 2)
  salePrice          Decimal?      @db.Decimal(12, 2)
  currencyCode       String        @default("UZS")
  status             ProductStatus @default(DRAFT)
  hasVariants        Boolean       @default(false)
  totalStock         Int           @default(0)
  isVisible          Boolean       @default(true)
  isFeatured         Boolean       @default(false)
  sku                String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  store          Store               @relation(fields: [storeId], references: [id])
  globalCategory GlobalCategory?     @relation(fields: [globalCategoryId], references: [id])
  storeCategory  StoreCategory?      @relation(fields: [storeCategoryId], references: [id])
  images         ProductImage[]
  optionGroups   ProductOptionGroup[]
  variants       ProductVariant[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  threads        ChatThread[]
  attributes     ProductAttribute[]

  @@index([storeId])
  @@index([globalCategoryId])
  @@index([storeCategoryId])
  @@index([status])
  @@index([isVisible])
  @@map("products")
}

model ProductAttribute {
  id        String  @id @default(uuid())
  productId String
  name      String
  value     String
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_attributes")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  mediaId   String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   MediaFile @relation(fields: [mediaId], references: [id])

  @@index([productId])
  @@map("product_images")
}

model ProductOptionGroup {
  id        String   @id @default(uuid())
  productId String
  name      String
  code      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product              @relation(fields: [productId], references: [id])
  values  ProductOptionValue[]

  @@unique([productId, code])
  @@index([productId])
  @@map("product_option_groups")
}

model ProductOptionValue {
  id            String   @id @default(uuid())
  optionGroupId String
  value         String
  code          String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  optionGroup ProductOptionGroup             @relation(fields: [optionGroupId], references: [id])
  variants    ProductVariantOptionValue[]

  @@unique([optionGroupId, code])
  @@index([optionGroupId])
  @@map("product_option_values")
}

model ProductVariant {
  id               String    @id @default(uuid())
  productId        String
  sku              String
  barcode          String?
  titleOverride    String?
  priceOverride    Decimal?  @db.Decimal(12, 2)
  oldPriceOverride Decimal?  @db.Decimal(12, 2)
  salePriceOverride Decimal? @db.Decimal(12, 2)
  stockQuantity    Int       @default(0)
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  product       Product                    @relation(fields: [productId], references: [id])
  optionValues  ProductVariantOptionValue[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  inventoryMovements InventoryMovement[]

  @@unique([productId, sku])
  @@index([productId])
  @@index([isActive])
  @@index([stockQuantity])
  @@map("product_variants")
}

model ProductVariantOptionValue {
  variantId     String
  optionValueId String

  variant     ProductVariant     @relation(fields: [variantId], references: [id])
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id])

  @@id([variantId, optionValueId])
  @@map("product_variant_option_values")
}

model InventoryMovement {
  id            String                @id @default(uuid())
  productId     String
  variantId     String?
  movementType  InventoryMovementType
  quantityDelta Int
  referenceType String?               // order | admin | seller
  referenceId   String?
  note          String?
  createdAt     DateTime              @default(now())

  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@index([referenceId])
  @@map("inventory_movements")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model Cart {
  id           String   @id @default(uuid())
  buyerId      String?
  sessionKey   String?
  storeId      String
  status       String   @default("active") // active | converted | merged | expired
  currencyCode String   @default("UZS")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime?

  buyer  Buyer?     @relation(fields: [buyerId], references: [id])
  store  Store      @relation(fields: [storeId], references: [id])
  items  CartItem[]
  orders Order[]

  @@index([buyerId])
  @@index([sessionKey])
  @@index([storeId])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id                  String   @id @default(uuid())
  cartId              String
  productId           String
  variantId           String?
  quantity            Int
  unitPriceSnapshot   Decimal  @db.Decimal(12, 2)
  salePriceSnapshot   Decimal? @db.Decimal(12, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id                 String        @id @default(uuid())
  orderNumber        String        @unique
  buyerId            String?
  storeId            String
  sellerId           String
  cartId             String?
  status             OrderStatus   @default(PENDING)
  paymentMethod      PaymentMethod
  paymentStatus      PaymentStatus @default(UNPAID)
  currencyCode       String        @default("UZS")
  subtotalAmount     Decimal       @db.Decimal(12, 2)
  discountAmount     Decimal       @default(0) @db.Decimal(12, 2)
  deliveryFeeAmount  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal       @db.Decimal(12, 2)
  deliveryType       DeliveryType
  customerFullName   String
  customerPhone      String
  customerComment    String?
  sellerInternalNote String?
  city               String?
  region             String?
  addressLine1       String?
  addressLine2       String?
  landmark           String?
  placedAt           DateTime      @default(now())
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  completedAt        DateTime?
  cancelReason       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  buyer   Buyer?              @relation(fields: [buyerId], references: [id])
  store   Store               @relation(fields: [storeId], references: [id])
  seller  Seller              @relation(fields: [sellerId], references: [id])
  cart    Cart?               @relation(fields: [cartId], references: [id])
  items   OrderItem[]
  history OrderStatusHistory[]
  threads ChatThread[]

  @@index([buyerId])
  @@index([storeId])
  @@index([sellerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([placedAt])
  @@map("orders")
}

model OrderItem {
  id                       String   @id @default(uuid())
  orderId                  String
  productId                String?
  variantId                String?
  productTitleSnapshot     String
  productDescriptionSnapshot String?
  skuSnapshot              String?
  variantLabelSnapshot     String?
  quantity                 Int
  unitPriceSnapshot        Decimal  @db.Decimal(12, 2)
  oldPriceSnapshot         Decimal? @db.Decimal(12, 2)
  salePriceSnapshot        Decimal? @db.Decimal(12, 2)
  lineTotalAmount          Decimal  @db.Decimal(12, 2)
  primaryImageUrlSnapshot  String?
  createdAt                DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id              String   @id @default(uuid())
  orderId         String
  oldStatus       String?
  newStatus       String
  changedByUserId String?
  comment         String?
  createdAt       DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

model ChatThread {
  id            String     @id @default(uuid())
  threadType    ThreadType
  productId     String?
  orderId       String?
  buyerId       String?
  sellerId      String
  status        String     @default("active")
  lastMessageId    String?
  lastMessageAt    DateTime?
  buyerLastReadAt  DateTime?
  sellerLastReadAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  product  Product?      @relation(fields: [productId], references: [id])
  order    Order?        @relation(fields: [orderId], references: [id])
  buyer    Buyer?        @relation(fields: [buyerId], references: [id])
  seller   Seller        @relation(fields: [sellerId], references: [id])
  messages ChatMessage[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
  @@index([orderId])
  @@index([lastMessageAt])
  @@map("chat_threads")
}

model ChatMessage {
  id               String   @id @default(uuid())
  threadId         String
  senderUserId     String
  messageType      String   @default("text") // text | image | system
  body             String?
  productContextId String?
  orderContextId   String?
  isDeleted        Boolean   @default(false)
  reportedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  thread ChatThread @relation(fields: [threadId], references: [id])

  @@index([threadId])
  @@index([senderUserId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────
// MEDIA
// ─────────────────────────────────────────────

model MediaFile {
  id          String          @id @default(uuid())
  ownerUserId String?
  bucket      String
  objectKey   String
  mimeType    String
  fileSize    BigInt
  width       Int?
  height      Int?
  visibility  MediaVisibility @default(PUBLIC)
  createdAt   DateTime        @default(now())

  productImages              ProductImage[]
  sellerVerificationDocuments SellerVerificationDocument[]

  @@index([ownerUserId])
  @@map("media_files")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model InAppNotification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // order.status_changed | store.approved | store.rejected | new_order | new_message | seller.verified | moderation.action
  title     String
  body      String
  data      Json     @default("{}")
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("in_app_notifications")
}

model NotificationPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  mobilePushEnabled Boolean  @default(true)
  webPushEnabled    Boolean  @default(false)
  telegramEnabled   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("notification_preferences")
}

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  platform   String   // ios | android | web
  provider   String   // expo | fcm | webpush
  endpoint   String
  p256dh     String?
  auth       String?
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationLog {
  id             String   @id @default(uuid())
  userId         String
  channel        String   // mobile_push | telegram
  eventType      String
  payload        Json
  deliveryStatus String   // queued | sent | failed
  failureReason  String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([channel])
  @@index([eventType])
  @@index([deliveryStatus])
  @@map("notification_logs")
}

// ─────────────────────────────────────────────
// ADMIN & MODERATION
// ─────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(uuid())
  userId       String   @unique
  isSuperadmin Boolean  @default(true)
  createdAt    DateTime @default(now())

  user              User               @relation(fields: [userId], references: [id])
  moderationCases   ModerationCase[]
  moderationActions ModerationAction[]

  @@map("admin_users")
}

model ModerationCase {
  id               String   @id @default(uuid())
  entityType       String   // seller | store | product | message
  entityId         String
  caseType         String   // verification | abuse | manual_review
  status           String   @default("open")
  reason           String?
  assignedAdminId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assignedAdmin AdminUser?         @relation(fields: [assignedAdminId], references: [id])
  actions       ModerationAction[]

  @@index([entityType, entityId])
  @@index([status])
  @@map("moderation_cases")
}

model ModerationAction {
  id          String   @id @default(uuid())
  caseId      String?
  entityType  String
  entityId    String
  actionType  String   // approve | reject | hide | suspend | restore | block
  adminUserId String
  comment     String?
  createdAt   DateTime @default(now())

  case      ModerationCase? @relation(fields: [caseId], references: [id])
  adminUser AdminUser       @relation(fields: [adminUserId], references: [id])

  @@index([entityType, entityId])
  @@index([adminUserId])
  @@map("moderation_actions")
}

// Append-only. Never UPDATE or DELETE.
model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorType   String   // buyer | seller | admin | system
  entityType  String
  entityId    String
  action      String
  payload     Json?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

// Append-only. Never UPDATE or DELETE.
model AnalyticsEvent {
  id          String   @id @default(uuid())
  actorUserId String?
  actorType   String?
  storeId     String?
  eventName   String
  eventPayload Json    @default("{}")
  sessionKey  String?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([storeId])
  @@index([eventName])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─────────────────────────────────────────────
// BROADCAST
// ─────────────────────────────────────────────

model BroadcastLog {
  id          String   @id @default(uuid())
  message     String
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())

  creator User @relation(fields: [createdBy], references: [id])

  @@index([createdAt])
  @@map("broadcast_logs")
}
