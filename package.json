{
  "name": "savdo",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web-buyer": "pnpm --filter web-buyer dev",
    "dev:web-seller": "pnpm --filter web-seller dev",
    "dev:admin": "pnpm --filter admin dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter db prisma generate",
    "db:migrate:dev": "pnpm --filter db prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter db prisma migrate deploy",
    "db:studio": "pnpm --filter db prisma studio",
    "db:seed": "pnpm --filter db seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
