{
  "name": "savdo",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web-buyer": "pnpm --filter web-buyer dev",
    "dev:web-seller": "pnpm --filter web-seller dev",
    "dev:admin": "pnpm --filter admin dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "pnpm --filter api exec tsc --noEmit",
    "db:generate": "pnpm --filter db run generate",
    "db:migrate:dev": "pnpm --filter db run migrate:dev",
    "db:migrate:deploy": "pnpm --filter db run migrate:deploy",
    "db:studio": "pnpm --filter db run studio",
    "db:seed": "pnpm --filter db run seed",
    "docker:up": "docker compose --env-file .env.docker up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "docker:reset": "docker compose down -v && docker compose --env-file .env.docker up --build -d",
    "docker:typecheck": "docker compose --env-file .env.docker run --rm --no-deps api sh -c 'pnpm --filter api exec tsc --noEmit'"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
